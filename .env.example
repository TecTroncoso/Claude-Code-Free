# NVIDIA API key for upstream NVIDIA NIM endpoints.
# In Render: required RenderDashboard secret ─── Service → Environment → Add Secret.
# Locally: copy this file to `.env` and fill in your real key.
NVIDIA_API_KEY=<from-render-dashboard>

# LiteLLM proxy master key. Required by litellm[proxy] to authorize access to
# management endpoints (`/health`, `/metrics`, `/key/generate`). In Render: set as
# a dashboard secret. Pick a long random string in production; "dev-master-key"
# is fine for local development.
LITELLM_MASTER_KEY=<from-render-dashboard>

# Default upstream NIM model the proxy uses when a request omits `model`.
# Swap to any other currently-served NIM model id via env without a code change.
NIM_DEFAULT_MODEL=nvidia_nim/minimaxai/minimax-m3

# Comma-separated allowlist of valid model ids. The proxy fails fast on boot if
# NIM_DEFAULT_MODEL is not in this list.
NIM_MODEL_ALLOWLIST=nvidia_nim/minimaxai/minimax-m3

# Reserved for the future rate-limit slice. Leave commented out today.
# RATE_LIMIT_BURST=1000
# RATE_LIMIT_REFILL_PER_SEC=50
