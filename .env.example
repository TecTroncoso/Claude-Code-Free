# NVIDIA API key for upstream NVIDIA NIM endpoints.
# In Render: this MUST be set in the dashboard (Service → Environment → Add Secret).
# Locally: copy this file to `.env` and fill in your real key.
NVIDIA_API_KEY=<from-render-dashboard>

# Full LiteLLM model path including the provider prefix.
# Format: nvidia_nim/<model-id>
# The yaml reads this directly, so changing the model is a one-line edit here.
NIM_DEFAULT_MODEL=nvidia_nim/minimaxai/minimax-m3

# Comma-separated allowlist of valid model paths. The proxy fails fast on boot if
# NIM_DEFAULT_MODEL is not in this list.
NIM_MODEL_ALLOWLIST=nvidia_nim/minimaxai/minimax-m3

# Reserved for the future rate-limit slice. Leave commented out today.
# RATE_LIMIT_BURST=1000
# RATE_LIMIT_REFILL_PER_SEC=50
